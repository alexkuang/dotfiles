prefix_rule(pattern=["uv", "pip", "list"], decision="allow")
prefix_rule(pattern=["uv", "python", "list"], decision="allow")
prefix_rule(pattern=["uv", "sync"], decision="allow")
prefix_rule(pattern=["uv", "tool", "list"], decision="allow")
prefix_rule(pattern=["uv", "tree"], decision="allow")
