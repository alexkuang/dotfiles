prefix_rule(pattern=["contextbridge", "plan"], decision="allow")
prefix_rule(pattern=["docker", ["diff", "images", "info", "inspect", "logs", "pause", "port", "ps", "pull", "restart", "start", "stats", "stop", "top", "unpause", "version"]], decision="allow")
prefix_rule(pattern=["docker", "compose", ["build", "config", "create", "images", "logs", "ls", "pause", "port", "ps", "pull", "restart", "start", "stop", "top", "unpause", "up", "version"]], decision="allow")
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")
prefix_rule(pattern=["gh", "issue", ["list", "status", "view"]], decision="allow")
prefix_rule(pattern=["gh", "pr", ["checks", "diff", "list", "status", "view"]], decision="allow")
prefix_rule(pattern=["gh", "release", ["list", "view"]], decision="allow")
prefix_rule(pattern=["gh", "repo", ["list", "view"]], decision="allow")
prefix_rule(pattern=["gh", "run", ["list", "view", "watch"]], decision="allow")
prefix_rule(pattern=["gh", "search"], decision="allow")
prefix_rule(pattern=["gh", "status"], decision="allow")
prefix_rule(pattern=["gh", "workflow", ["list", "view"]], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "checkout"], decision="allow")
prefix_rule(pattern=["git", "clone"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
prefix_rule(pattern=["git", "init"], decision="allow")
prefix_rule(pattern=["mix", "compile"], decision="allow")
prefix_rule(pattern=["mix", "credo"], decision="allow")
prefix_rule(pattern=["mix", "deps.get"], decision="allow")
prefix_rule(pattern=["mix", "dialyzer"], decision="allow")
prefix_rule(pattern=["mix", "ecto.gen.migration"], decision="allow")
prefix_rule(pattern=["mix", "ecto.migrate"], decision="allow")
prefix_rule(pattern=["mix", "format"], decision="allow")
prefix_rule(pattern=["mix", "help"], decision="allow")
prefix_rule(pattern=["mix", "hex.info"], decision="allow")
prefix_rule(pattern=["mix", "test"], decision="allow")
prefix_rule(pattern=["npm"], decision="forbidden", justification="npm sucks")
prefix_rule(pattern=["pnpm", "install"], decision="allow")
prefix_rule(pattern=["psql"], decision="allow")
prefix_rule(pattern=["uv", "--version"], decision="allow")
prefix_rule(pattern=["uv", "export"], decision="allow")
prefix_rule(pattern=["uv", "lock"], decision="allow")
